# PostgreSQL connection string (Neon pooled URL recommended for serverless)
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Secret used to sign session JWTs. Generate with: openssl rand -base64 48
JWT_SECRET=

# Optional: a default GitHub token for the "Export to GitHub" feature.
# Users can also paste their own PAT at export time, so this can be left blank.
GITHUB_TOKEN=
